{
  "name": "auto-updater",
  "version": "0.3.2",
  "description": "自动更新检测程序 - 监控源目录(SMB 挂载)变更,镜像同步到目标目录,带 N 版备份",
  "main": "out/main/index.cjs",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win --x64 --publish never",
    "build:win:portable": "npm run build && electron-builder --win portable --x64 --publish never",
    "build:mac": "npm run build && electron-builder --mac --publish never",
    "build:mac:arm64": "npm run build && electron-builder --mac --arm64 --publish never",
    "build:mac:x64": "npm run build && electron-builder --mac --x64 --publish never",
    "build:linux": "npm run build && electron-builder --linux --x64 --publish never",
    "build:linux:arm64": "npm run build && electron-builder --linux --arm64 --publish never",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "sync-once": "node --import tsx src/core/cli.ts --once",
    "watch": "node --import tsx src/core/cli.ts --watch",
    "init-config": "node --import tsx src/core/cli.ts --init",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && vue-tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "electron-log": "^5.4.4",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multicast-dns": "^7.2.5",
    "naive-ui": "^2.44.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "^22.7.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.1.4",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.1",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.6"
  },
  "build": {
    "appId": "com.local.auto-updater",
    "productName": "自动更新检测",
    "icon": "resources/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/remote-ui",
        "to": "remote-ui"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.utilities",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Utility",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "自动更新检测"
    },
    "asar": true
  }
}
