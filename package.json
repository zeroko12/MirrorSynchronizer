{
  "name": "auto-updater",
  "version": "0.1.0",
  "description": "自动更新检测程序 - 监控源目录(SMB 挂载)变更,镜像同步到目标目录,带 N 版备份",
  "main": "out/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win --x64",
    "build:win:portable": "npm run build && electron-builder --win portable --x64",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "sync-once": "node --import tsx src/core/cli.ts --once",
    "watch": "node --import tsx src/core/cli.ts --watch",
    "init-config": "node --import tsx src/core/cli.ts --init",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && vue-tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^11.10.0",
    "electron-log": "^5.4.4",
    "fast-glob": "^3.3.2",
    "naive-ui": "^2.44.1",
    "vfonts": "^0.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.7.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "fake-indexeddb": "^6.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.1",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.6"
  },
  "build": {
    "appId": "com.local.auto-updater",
    "productName": "自动更新检测",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "自动更新检测"
    },
    "asar": true
  }
}
